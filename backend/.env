# StudenHub — Environment Variables
# Fill in your values before running locally
# On Render: add these in Dashboard → Your Service → Environment

# Turso database URL — get this from: turso db show studenhub
TURSO_URL=libsql://your-database-name.turso.io

# Turso auth token — get this from: turso db tokens create studenhub
TURSO_TOKEN=your-turso-auth-token-here

# Secret key for JWT tokens — change this to a long random string!
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=studenhub_change_this_secret_in_production

# Port the server runs on
PORT=3000
